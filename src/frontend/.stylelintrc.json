{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "variants",
          "responsive",
          "screen"
        ]
      }
    ],
    "declaration-block-trailing-semicolon": null,
    "no-descending-specificity": null,
    "font-family-name-quotes": null,
    "keyframes-name-pattern": null,
    "rule-empty-line-before": null
  },
  "ignoreFiles": [
    "build/**/*",
    "node_modules/**/*",
    "public/**/*"
  ]
}