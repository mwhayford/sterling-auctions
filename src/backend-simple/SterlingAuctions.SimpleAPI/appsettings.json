{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "InMemoryDb",
    "Redis": "redis:6379"
  },
  "JwtSettings": {
    "SecretKey": "sterling-auctions-super-secret-jwt-key-at-least-32-characters-long!",
    "Issuer": "sterling-auctions",
    "Audience": "sterling-auctions-users",
    "TokenExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "GoogleOAuth": {
    "ClientId": "your-google-client-id.apps.googleusercontent.com",
    "ClientSecret": "your-google-client-secret",
    "RedirectUri": "https://localhost:5000/api/auth/google-callback"
  },
  "RedisSettings": {
    "ConnectionString": "redis:6379",
    "InstanceName": "SterlingAuctions",
    "DefaultDatabase": 0,
    "ConnectTimeout": 10000,
    "SyncTimeout": 10000,
    "AbortOnConnectFail": false,
    "RetryCount": 5,
    "RetryDelayMs": 2000
  },
  "CacheSettings": {
    "DefaultExpirationMinutes": 30,
    "AuctionExpirationMinutes": 15,
    "UserExpirationMinutes": 60,
    "StatisticsExpirationMinutes": 5,
    "SearchExpirationMinutes": 10,
    "NotificationExpirationMinutes": 20,
    "WatchlistExpirationMinutes": 30
  },
  "StripeSettings": {
    "SecretKey": "sk_test_your_stripe_secret_key_here",
    "PublishableKey": "pk_test_your_stripe_publishable_key_here",
    "WebhookSecret": "whsec_your_stripe_webhook_secret_here",
    "ApplicationFeePercentage": 5.0,
    "MinimumApplicationFee": 0.50,
    "MaximumApplicationFee": 50.00,
    "DefaultCurrency": "usd",
    "SupportedCurrencies": ["usd", "eur", "gbp", "cad", "aud"],
    "PaymentMethodTypes": ["card"],
    "AutomaticPaymentMethods": ["card"],
    "CaptureMethod": "automatic",
    "ConfirmationMethod": "automatic",
    "SetupFutureUsage": "off_session",
    "EnableSavePaymentMethods": true,
    "EnableRefunds": true,
    "RefundTimeLimitDays": 30,
    "EnablePartialRefunds": true,
    "WebhookEndpoint": "/api/webhook/stripe",
    "EnableWebhookVerification": true,
    "TestMode": true,
      "EnableLogging": true,
      "LogLevel": "Info"
    },
    "ConnectionManager": {
      "HealthCheckInterval": 30000,
      "MaxFailedAttempts": 3,
      "LatencyThreshold": 1000,
      "HeartbeatTimeout": 60000,
      "AutoSwitchTransport": true,
      "AutoReconnect": true,
      "PreferredTransports": ["websockets", "sse", "longpolling", "polling"],
      "MaxConnectionsPerUser": 5,
      "ConnectionCleanupInterval": 300000,
      "EnableConnectionLogging": true,
      "EnablePerformanceMetrics": true
    },
    "SignalRPerformance": {
      "LatencyWarningThreshold": 500,
      "LatencyCriticalThreshold": 1000,
      "ErrorRateWarningThreshold": 5,
      "ErrorRateCriticalThreshold": 10,
      "ReconnectRateWarningThreshold": 10,
      "ReconnectRateCriticalThreshold": 20,
      "HeartbeatTimeout": 60000,
      "MessageSizeWarningThreshold": 1048576,
      "MessageSizeCriticalThreshold": 5242880,
      "MaxConnectionsPerUser": 5,
      "MetricsRetentionDays": 30,
      "EnableRealTimeMonitoring": true,
      "EnablePerformanceAlerts": true,
      "AlertCooldownMinutes": 5
    },
  "CloudWatch": {
    "Enabled": true,
    "Region": "us-east-1",
    "Namespace": "SterlingAuctions/Application",
    "LogGroup": "/aws/sterling-auctions/application",
    "LogRetentionDays": 14
  },
  "Seq": {
    "Enabled": true,
    "Url": "http://localhost:5341",
    "ApiKey": ""
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.AwsCloudWatch", "Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sterling-auctions-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  }
}