{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=sterling_auctions;Username=postgres;Password=password",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "SterlingAuctions",
    "Audience": "SterlingAuctionsUsers",
    "TokenExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "https://localhost:3001"
  ],
  "Stripe": {
    "PublishableKey": "pk_test_your_stripe_publishable_key",
    "SecretKey": "sk_test_your_stripe_secret_key",
    "WebhookSecret": "whsec_your_webhook_secret"
  },
  "GoogleAuth": {
    "ClientId": "your_google_client_id.apps.googleusercontent.com",
    "ClientSecret": "your_google_client_secret"
  },
  "Email": {
    "SendGridApiKey": "your_sendgrid_api_key",
    "FromEmail": "noreply@sterling-auctions.com",
    "FromName": "Sterling Auctions"
  },
  "AWS": {
    "AccessKey": "your_aws_access_key",
    "SecretKey": "your_aws_secret_key",
    "Region": "us-east-1",
    "BucketName": "sterling-auctions-storage"
  },
  "FeatureFlags": {
    "AdminPanel": true,
    "AdvancedAnalytics": false,
    "MobileApp": true,
    "PayPalIntegration": true,
    "GoogleAuth": true
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sterling-auctions-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  },
  "HealthChecks": {
    "UI": {
      "HealthChecksUIEnabled": true,
      "HealthChecksUIPath": "/health-ui"
    }
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "GeneralRules": {
      "RequestsPerMinute": 60,
      "RequestsPerHour": 1000
    },
    "AuthRules": {
      "RequestsPerMinute": 10,
      "RequestsPerHour": 100
    }
  },
  "Caching": {
    "DefaultCacheTimeInMinutes": 15,
    "UserCacheTimeInMinutes": 30,
    "AuctionCacheTimeInMinutes": 5
  }
}
